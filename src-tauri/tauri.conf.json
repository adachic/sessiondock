{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SessionDock",
  "version": "0.2.0",
  "identifier": "dev.sessiondock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SessionDock",
        "label": "main",
        "width": 420,
        "height": 520,
        "resizable": true,
        "decorations": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
